# ==============================================================================
# TK101 AI Platform — Environment Variables Template
# ==============================================================================
# 실제 .env 파일을 만들 때 이 파일을 복사:  cp .env.example .env
# .env 파일은 절대 커밋 금지 (.gitignore에 등록됨)
# ==============================================================================

# -------- Backend (FastAPI) --------
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://tk101:tk101_dev_password@postgres:5432/tk101
DATABASE_URL_SYNC=postgresql+psycopg://tk101:tk101_dev_password@postgres:5432/tk101

# PostgreSQL 컨테이너 설정
POSTGRES_USER=tk101
POSTGRES_PASSWORD=tk101_dev_password
POSTGRES_DB=tk101

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (Sprint 1 auth scope에서 사용)
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# Claude API (Sprint 2 chat scope에서 사용)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# CORS (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000

# -------- Frontend (Next.js) --------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -------- Deployment (GitHub Secrets로 관리) --------
# CVM_HOST=<your-cvm-ip>
# CVM_USER=<deploy-user>
# CVM_SSH_KEY=<private-key>
