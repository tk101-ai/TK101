# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Environment
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs / local
*.log
.bkit/

# 로컬 자격증명 드롭 위치 — git commit 금지 (T9 텔레그램 자격증명, 임시 토큰 등)
.local/

# 평문 키/메모 — 절대 commit 금지 (텐센트 API.txt 등에 SecretKey 평문 포함)
업무개선요구사항/AI 플레이그라운드/텐센트 API.txt
업무개선요구사항/AI 플레이그라운드/API 호출 예시.txt

# 1회용 probe / dump 스크립트와 산출물 — 평문 키 박혀있는 경우 있음
scripts/smoke_tencent_token.py
scripts/probe_*.py
scripts/dump_*.py
scripts/_*.txt

# frontend 빌드 로그 임시 (Agent가 만들 수 있음)
frontend/.build_*.txt

# Claude Code worktrees (병렬 에이전트 격리 작업 폴더 — commit 대상 아님)
.claude/worktrees/

# E2E 결과물 (Playwright 리포트·트레이스·로컬 node_modules)
tests/e2e/node_modules/
tests/e2e/test-results/
tests/e2e/playwright-report/
tests/e2e/playwright/.cache/

# 로컬 NAS 스텁 (Windows 개발 환경 전용 — 라이브 서버는 SSHFS /mnt/nas 사용)
/nas-stub/*
!/nas-stub/README.txt

.dev.env
