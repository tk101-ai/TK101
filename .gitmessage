# <type>(<scope>): <subject>
#
# <body: 왜 변경했는지, 영향은 무엇인지>
#
# ─────────────────────────────────────────────
# type      설명
# ─────────────────────────────────────────────
# feat      새로운 기능
# fix       버그 수정
# refactor  동작 변경 없는 코드 개선
# build     빌드/패키징 (Dockerfile, pyproject)
# ci        CI/CD 파이프라인
# docs      문서만 변경
# test      테스트 추가/수정
# chore     기타 유지보수 (설정 등)
# perf      성능 개선
# style     포맷/린트 (동작 동일)
# ─────────────────────────────────────────────
# scope 예시: backend, ci, docker, docs, root
# ─────────────────────────────────────────────
# subject: 명령형, 50자 이내, 마침표 없음
#
# 자세한 규약: docs/COMMIT_CONVENTION.md
